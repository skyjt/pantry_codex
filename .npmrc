electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

# @types/node 故意锁 16.x（匹配 Electron 22 内置的 Node 16.17 运行时，红线执法），
# 与 vite5 的 peerOptional @types/node>=18 仅为类型声明冲突，运行时无影响 —— 放行。
# 本项目所有依赖均精确锁版本（见 tech-design §1 依赖纪律），peer 自动解析价值有限。
legacy-peer-deps=true

# native 模块（better-sqlite3）一律面向 Electron 22 ABI 构建，而非开发机 Node：
# 开发机 Node 太新（V8 API 不同）会导致老版本 better-sqlite3 源码编译失败，
# 而我们的运行时只有 Electron。数据库测试也在 Electron 运行时跑（npm run test:db）。
runtime=electron
target=22.3.27
disturl=https://electronjs.org/headers
